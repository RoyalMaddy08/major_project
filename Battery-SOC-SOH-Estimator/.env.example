# ============================================================
# LOCAL DEVELOPMENT — copy this file to .env and fill in values
# PRODUCTION — set these as Environment Variables in Vercel Dashboard
#              (Project Settings > Environment Variables)
#              NEVER commit .env with real credentials to Git.
# ============================================================

# MongoDB URI
# LOCAL:      mongodb://localhost:27017/
# PRODUCTION: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net
MONGODB_URI=mongodb://localhost:27017/

# MongoDB database and collection names (same for local and prod)
MONGODB_DB_NAME=battery_estimation_db
MONGODB_READINGS_COLLECTION=readings
MONGODB_STATE_COLLECTION=sim_state

# Flask server settings (ignored by Vercel, used locally)
PORT=5000
FLASK_DEBUG=False

# Path to trained ESN model pickle (relative to app.py)
MODEL_PATH=model_rc.pkl

# Simulator step interval in seconds
SIMULATION_STEP_DELAY=1.0

